# Copy to .env.local and fill in real values (gitignored)

# Supabase (required)
# Get from: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_anon_key_here

# Sentry (optional, error monitoring)
# Get DSN from: https://sentry.io/settings/projects/_/keys/
VITE_SENTRY_DSN=

# Ollama (optional, local LLM)
# If unset, falls back to http://localhost:11434 which only works in dev.
# Set to a Cloudflare Tunnel URL (https://ollama.yourdomain.com) to enable in prod.
VITE_OLLAMA_URL=
